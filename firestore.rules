rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isMember(familyId) {
      return exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /families/{familyId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn() && isMember(familyId);

      match /members/{memberId} {
        // Reading the member list (not just isMember families) has to be allowed to
        // any signed-in user: a brand-new joiner isn't a member yet when the entry
        // flow reads the list to check for an existing membership / pick a color.
        // The shared family password is the real gate here, same as /families read.
        allow read: if signedIn();
        allow create: if signedIn() && request.auth.uid == memberId;
        allow update: if signedIn() && request.auth.uid == memberId;
        allow delete: if signedIn() && request.auth.uid == memberId;
      }

      match /events/{eventId} {
        allow read: if signedIn() && isMember(familyId);
        allow create: if signedIn() && isMember(familyId) && request.resource.data.createdBy == request.auth.uid;
        allow update, delete: if signedIn() && isMember(familyId);
      }

      match /tasks/{taskId} {
        allow read: if signedIn() && isMember(familyId);
        allow create: if signedIn() && isMember(familyId) && request.resource.data.createdBy == request.auth.uid;
        allow update, delete: if signedIn() && isMember(familyId);
      }

      match /shopping/{itemId} {
        allow read: if signedIn() && isMember(familyId);
        allow create: if signedIn() && isMember(familyId) && request.resource.data.requestedBy == request.auth.uid;
        allow update, delete: if signedIn() && isMember(familyId);
      }

      match /wishes/{wishId} {
        allow read: if signedIn() && isMember(familyId);
        allow create: if signedIn() && isMember(familyId) && request.resource.data.requestedBy == request.auth.uid;
        allow update, delete: if signedIn() && isMember(familyId);
      }

      match /notices/{noticeId} {
        allow read: if signedIn() && isMember(familyId);
        allow create: if signedIn() && isMember(familyId) && request.resource.data.createdBy == request.auth.uid;
        allow update, delete: if signedIn() && isMember(familyId);
      }

      match /anniversaries/{annivId} {
        allow read: if signedIn() && isMember(familyId);
        allow create: if signedIn() && isMember(familyId) && request.resource.data.createdBy == request.auth.uid;
        allow update, delete: if signedIn() && isMember(familyId);
      }
    }
  }
}
